# Frontend build config (Vite). Copy to .env.local for dev, or set in the Pages workflow.
# All non-secret. With these unset, the app runs against the seed fixture, local-only (no sign-in/PRs).

# Public backing repo (read directly from raw.githubusercontent)
VITE_GH_OWNER=dginev
VITE_GH_REPO=mathml-intent-open
VITE_GH_BASE=main
VITE_GH_FILE=open.yml

# GitHub App client id (public) + the auth/PR service base URL
VITE_GH_CLIENT_ID=Iv23li8qbVqkKOVJWpJ1
VITE_GH_SERVICE=https://intent-api.latexml.rs
