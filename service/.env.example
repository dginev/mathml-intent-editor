# Copy to the VM as /etc/mathml-intent/service.env (root-only, 600) and fill the secret.

PORT=8787
# Comma-separated allowed browser origins (scheme+host only — no path).
ALLOWED_ORIGIN=https://dginev.github.io,http://localhost:5173

# Classic GitHub OAuth App (user authorization, scope public_repo). The client id is also exposed to the
# browser as VITE_GH_CLIENT_ID; the secret stays here so the service can do the code→token exchange.
GH_CLIENT_ID=__oauth_app_client_id__
GH_CLIENT_SECRET=__oauth_app_client_secret__
