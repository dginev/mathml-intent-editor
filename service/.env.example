# Copy to the VM as /etc/mathml-intent/service.env (root-only, 600) and fill the secrets.
# Non-secret values are pre-filled for the dginev/mathml-intent-open setup.

PORT=8787
# Comma-separated allowed browser origins (scheme+host only — no path).
ALLOWED_ORIGIN=https://dginev.github.io,http://localhost:5173

# GitHub App (identity OAuth + bot installation token)
GH_APP_ID=3916896
GH_CLIENT_ID=Iv23li8qbVqkKOVJWpJ1
GH_INSTALLATION_ID=136850978
GH_CLIENT_SECRET=__paste_the_App_client_secret_here__
GH_PRIVATE_KEY_PATH=/etc/mathml-intent/app-private-key.pem

# Identity-session signing secret (generate: `openssl rand -hex 32`)
JWT_SECRET=__generate_a_long_random_string__

# Backing data repo
REPO_OWNER=dginev
REPO_NAME=mathml-intent-open
BASE_BRANCH=main
FILE_PATH=open.yml
